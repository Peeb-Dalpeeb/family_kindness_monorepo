# ═══════════════════════════════════════════════════════════════
# Family Kindness Tracker — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in production values.
# This is the single source of truth for the entire monorepo.
# ═══════════════════════════════════════════════════════════════

# ── MongoDB Connection ────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/family-kindness

# ── Backend Server ────────────────────────────────────────────
PORT=3001

# ── JWT Authentication ────────────────────────────────────────
# Secret key for signing JWTs. Generate a strong random value:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET

# JWT token expiration (e.g., "2h", "7d")
JWT_EXPIRY=2h

# ── Admin PIN ─────────────────────────────────────────────────
# The 4-digit PIN that parents enter to authenticate.
# Stored server-side only; never exposed to the frontend.
ADMIN_PIN=1234

# ── Frontend (Vite) ──────────────────────────────────────────
# Vite env vars must be prefixed with VITE_
VITE_API_URL=http://localhost:3001/api
