{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "input": {
    "maxFileSize": 52428800
  },
  "output": {
    "filePath": "G:\\My Drive\\Applications\\Kindness Application\\repomix-output.xml",
    "style": "xml",
    "parsableStyle": true,
    "fileSummary": true,
    "directoryStructure": true,
    "files": true,
    "removeComments": false,
    "removeEmptyLines": false,
    "compress": false,
    "topFilesLength": 5,
    "showLineNumbers": true,
    "truncateBase64": false,
    "copyToClipboard": false,
    "includeFullDirectoryStructure": true,
    "tokenCountTree": true,
    "git": {
      "sortByChanges": true,
      "sortByChangesMaxCommits": 100,
      "includeDiffs": false,
      "includeLogs": false,
      "includeLogsCount": 50
    }
  },
  "include": [],
  "ignore": {
    "useGitignore": true,
    "useDotIgnore": false,
    "useDefaultPatterns": true,
    "customPatterns": [
      "repomix-output.xml",
      "repomix-output.txt",
      "repomix-output.md",
      "repomix-output.json",
      "docs/mockup.xml",
      "package-lock.json",
      "yarn.lock",
      "pnpm-lock.yaml",
      "bun.lockb",
      "*.png",
      "*.jpg",
      "*.jpeg",
      "*.gif",
      "*.svg",
      "*.webp",
      "*.ico",
      "*.pdf",
      "*.zip",
      "*.tar.gz",
      "*.mp4",
      "*.mp3",
      ".DS_Store",
      "Thumbs.db",
      "*.swp",
      "*.swo",
      "*~"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  },
  "tokenCount": {
    "encoding": "o200k_base"
  }
}