import React, { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { 
  Heart, 
  HelpCircle, 
  Plus, 
  ShieldAlert, 
  Sparkles, 
  Lock, 
  Unlock, 
  Smartphone, 
  Home, 
  Activity, 
  Info,
  Gift,
  Sun,
  Moon,
  ChevronRight,
  PlusCircle,
  X
} from 'lucide-react';

import { FamilyMember, KindnessEntry, PointsCategory } from './types';
import { INITIAL_MEMBERS, INITIAL_ENTRIES } from './data';
import { MilestoneBanner } from './components/MilestoneBanner';
import { RadialGauge } from './components/RadialGauge';
import { LogModal } from './components/LogModal';
import { ActivityFeed } from './components/ActivityFeed';
import { CinematicMilestone } from './components/CinematicMilestone';

export default function App() {
  // 1. Core State
  const [entries, setEntries] = useState<KindnessEntry[]>(() => {
    const saved = localStorage.getItem('family_kindness_logs');
    return saved ? JSON.parse(saved) : INITIAL_ENTRIES;
  });

  const members = INITIAL_MEMBERS;

  // Simulated Router Route State: '/dashboard' | '/admin'
  const [activeRoute, setActiveRoute] = useState<'/dashboard' | '/admin'>('/dashboard');
  
  // Modal toggle state
  const [isLogModalOpen, setIsLogModalOpen] = useState(false);
  
  // Parental authentication lock state
  const [isParentAuthenticated, setIsParentAuthenticated] = useState(false);
  const [pinInput, setPinInput] = useState('');
  const [pinError, setPinError] = useState('');
  const [showPinPrompt, setShowPinPrompt] = useState(false);

  // Cinematic milestone notification trigger state
  const [isCelebrationOpen, setIsCelebrationOpen] = useState(false);
  const [celebrationMilestoneCount, setCelebrationMilestoneCount] = useState(0);
  const [isRadialGlowActive, setIsRadialGlowActive] = useState(false);

  // Dark mode toggle (supports future extensibility from guidelines)
  const [themeMode, setThemeMode] = useState<'light' | 'dark'>('light');

  // 2. Synchronize to LocalStorage
  useEffect(() => {
    localStorage.setItem('family_kindness_logs', JSON.stringify(entries));
  }, [entries]);

  // Handle HTML document theme classes
  useEffect(() => {
    document.documentElement.setAttribute('data-theme', themeMode);
  }, [themeMode]);

  // 3. Computed Metrics and Dynamic Variables
  const totalPoints = entries.reduce((acc, entry) => acc + entry.pointsAwarded, 0);
  const completedMilestones = Math.floor(totalPoints / 1000);
  const currentProgressPoints = totalPoints % 1000;
  
  // Percent calculated from progress towards the next 1,000 pt milestone
  // Max percentage value fits 0% to 99% logic elegantly, or wraps nicely
  const percentage = Math.floor((currentProgressPoints / 1000) * 100);

  // 4. Ingestion Action Controllers
  const handleAddNewEntry = (newEntryData: {
    submittedBy: string;
    beneficiary: string;
    category: PointsCategory;
    pointsAwarded: number;
    description: string;
  }) => {
    const freshEntry: KindnessEntry = {
      id: `entry-${Date.now()}-${Math.random().toString(36).substr(2, 5)}`,
      timestamp: Date.now(),
      ...newEntryData,
    };

    const newEntries = [freshEntry, ...entries];
    const previousPoints = totalPoints;
    const newPoints = previousPoints + freshEntry.pointsAwarded;

    // Check if new point addition crosses another multiple of 1,000 points
    const previousCompleted = Math.floor(previousPoints / 1000);
    const postCompleted = Math.floor(newPoints / 1000);

    setEntries(newEntries);

    if (postCompleted > previousCompleted) {
      // Trigger cinematic milestone celebration
      setCelebrationMilestoneCount(postCompleted);
      setIsRadialGlowActive(true);
      // Timeout to open large full-screen milestone layout overlay
      setTimeout(() => {
        setIsCelebrationOpen(true);
      }, 600);
    }
  };

  const handleDeleteEntry = (id: string) => {
    if (window.confirm('Are you absolutely sure you want to delete this act of kindness? This will deduct its points from the collective meter.')) {
      setEntries((prev) => prev.filter((item) => item.id !== id));
    }
  };

  const handleUpdateEntry = (updated: KindnessEntry) => {
    const oldScore = totalPoints;
    const updatedEntries = entries.map((item) => (item.id === updated.id ? updated : item));
    const newScore = updatedEntries.reduce((acc, entry) => acc + entry.pointsAwarded, 0);
    
    setEntries(updatedEntries);

    const oldCompleted = Math.floor(oldScore / 1000);
    const newCompleted = Math.floor(newScore / 1000);

    if (newCompleted > oldCompleted) {
      setCelebrationMilestoneCount(newCompleted);
      setIsRadialGlowActive(true);
      setTimeout(() => {
        setIsCelebrationOpen(true);
      }, 600);
    }
  };

  // 5. Simulated Admin Authentication Keypad
  const handleAuthSubmit = (e?: React.FormEvent) => {
    if (e) e.preventDefault();
    if (pinInput === '1234') {
      setIsParentAuthenticated(true);
      setShowPinPrompt(false);
      setPinError('');
      setPinInput('');
      setActiveRoute('/admin');
    } else {
      setPinError('Incorrect PIN code. Try using: 1234');
      setPinInput('');
    }
  };

  const handleRouteSwitch = (target: '/dashboard' | '/admin') => {
    if (target === '/admin') {
      if (isParentAuthenticated) {
        setActiveRoute('/admin');
      } else {
        setShowPinPrompt(true);
        setPinInput('');
        setPinError('');
      }
    } else {
      setActiveRoute('/dashboard');
    }
  };

  // Instantly test milestone overflows
  const handleSimulatePointsGift = (pointsToAdd: number) => {
    const previousPoints = totalPoints;
    const newPoints = previousPoints + pointsToAdd;

    // Log a dynamic celebratory boost entry
    const simulationEntry: KindnessEntry = {
      id: `sim-${Date.now()}`,
      timestamp: Date.now(),
      submittedBy: members[0]?.id || 'mom',
      beneficiary: members[1]?.id || 'leo',
      category: 'Other',
      pointsAwarded: pointsToAdd,
      description: '🎁 Simulation bonus points granted by household parental administrator to celebrate family milestone animations!',
    };

    setEntries([simulationEntry, ...entries]);

    const previousCompleted = Math.floor(previousPoints / 1000);
    const postCompleted = Math.floor(newPoints / 1000);

    if (postCompleted > previousCompleted) {
      setCelebrationMilestoneCount(postCompleted);
      setIsRadialGlowActive(true);
      setTimeout(() => {
        setIsCelebrationOpen(true);
      }, 550);
    }
  };

  // Clear all data to re-test pristine states
  const handleResetApplication = () => {
    if (window.confirm('Reset everything to the original narrative logs?')) {
      setEntries(INITIAL_ENTRIES);
      setIsParentAuthenticated(false);
      setIsRadialGlowActive(false);
      setActiveRoute('/dashboard');
    }
  };

  return (
    <div className="min-h-screen bg-canvas text-primary-espresso overflow-y-auto px-4 py-6 md:py-10 transition-colors duration-300">
      
      {/* Upper Navigation Header Bar */}
      <header className="max-w-4xl mx-auto mb-8 flex flex-col md:flex-row items-center justify-between gap-4 border-b border-muted-espresso/10 pb-5">
        
        {/* Brand Title block with small icon */}
        <div className="flex items-center gap-3">
          <div className="w-10 h-10 rounded-2xl bg-kindness text-white flex items-center justify-center shadow-sm select-none">
            <Heart className="w-5 h-5 fill-white" />
          </div>
          <div>
            <h1 className="text-xl md:text-2xl font-bold tracking-tight font-sans text-primary-espresso flex items-center gap-2">
              Family Kindness Tracker
            </h1>
            <p className="text-xs text-muted-espresso font-medium md:mt-0.5">
              Turning household acts of gratitude and aid into shared wins.
            </p>
          </div>
        </div>

        {/* Action Controls & Router Switch Tab Toggles */}
        <div className="flex items-center gap-3 flex-wrap">
          
          {/* Theme Extensibility Selector */}
          <button
            onClick={() => setThemeMode(themeMode === 'light' ? 'dark' : 'light')}
            className="p-2.5 rounded-xl border border-muted-espresso/10 hover:bg-surface text-muted-espresso hover:text-primary-espresso transition-all cursor-pointer"
            title="Toggle theme mode"
          >
            {themeMode === 'light' ? <Moon className="w-4 h-4" /> : <Sun className="w-4 h-4 text-amber-400" />}
          </button>

          {/* Simulated Router Segment Toggles */}
          <div className="bg-surface/50 p-1 rounded-2xl border border-muted-espresso/10 flex items-center gap-1">
            <button
              onClick={() => handleRouteSwitch('/dashboard')}
              className={`flex items-center gap-1.5 px-3.5 py-2 rounded-xl text-xs font-semibold tracking-wide transition-all cursor-pointer ${
                activeRoute === '/dashboard'
                  ? 'bg-canvas text-kindness shadow-xs ring-1 ring-kindness/5'
                  : 'text-muted-espresso hover:text-primary-espresso'
              }`}
            >
              <Home className="w-3.5 h-3.5" />
              <span>Dashboard</span>
            </button>
            
            <button
              onClick={() => handleRouteSwitch('/admin')}
              className={`flex items-center gap-1.5 px-3.5 py-2 rounded-xl text-xs font-semibold tracking-wide transition-all cursor-pointer ${
                activeRoute === '/admin'
                  ? 'bg-canvas text-kindness shadow-xs ring-1 ring-kindness/5'
                  : 'text-muted-espresso hover:text-primary-espresso'
              }`}
            >
              {isParentAuthenticated ? <Unlock className="w-3.5 h-3.5" /> : <Lock className="w-3.5 h-3.5 text-amber-success" />}
              <span>Parent Hub</span>
            </button>
          </div>

        </div>

      </header>

      {/* Main Container Wrapper */}
      <main className="max-w-4xl mx-auto space-y-6">
        
        {/* Router Viewport Layer: /dashboard (Unauthenticated tablet layout) */}
        {activeRoute === '/dashboard' && (
          <div className="space-y-6 animate-fade-in relative pb-16">
            
            {/* 1. Top-Anchored Milestone Achievement indicator Banner */}
            <MilestoneBanner completedMilestones={completedMilestones} />

            {/* 2. Primary Focal Central Radial progress scale */}
            <div className="bg-surface/20 border border-muted-espresso/10 rounded-3xl p-6 md:p-8 flex flex-col items-center justify-center relative overflow-hidden shadow-xs">
              
              {/* Minimal decoration */}
              <div className="absolute top-4 left-4 flex items-center gap-1.5 text-[10px] bg-canvas px-2 text-muted-espresso border border-muted-espresso/5 py-1 rounded-lg">
                <Activity className="w-3 h-3 text-kindness" />
                <span>Weekly House Goal</span>
              </div>

              {/* Radial Gauge Dial */}
              <RadialGauge 
                percentage={percentage} 
                currentPoints={currentProgressPoints} 
                isGlowActive={isRadialGlowActive || completedMilestones > 0}
              />

              {/* Small statistic indicators helping children visually map points */}
              <div className="grid grid-cols-3 gap-6 max-w-sm w-full mx-auto text-center border-t border-muted-espresso/10 pt-5 mt-2">
                <div>
                  <span className="block text-[10px] text-muted-espresso uppercase font-bold">Total Points</span>
                  <span className="text-sm font-extrabold text-primary-espresso tabular-nums">{totalPoints}</span>
                </div>
                <div className="border-r border-l border-muted-espresso/10">
                  <span className="block text-[10px] text-muted-espresso uppercase font-bold">Next Milestone</span>
                  <span className="text-sm font-extrabold text-kindness tabular-nums">1,000 pt</span>
                </div>
                <div>
                  <span className="block text-[10px] text-muted-espresso uppercase font-bold">Logged Acts</span>
                  <span className="text-sm font-extrabold text-primary-espresso tabular-nums">{entries.length}</span>
                </div>
              </div>

            </div>

            {/* 3. Primary Target Action Hook */}
            <div className="flex flex-col items-center justify-center pt-2">
              <motion.button
                id="open-log-modal"
                whileHover={{ scale: 1.03 }}
                whileTap={{ scale: 0.98 }}
                onClick={() => setIsLogModalOpen(true)}
                className="px-8 py-5 rounded-full bg-kindness hover:bg-kindness/95 text-white font-extrabold tracking-wide hover:shadow-lg transition-all flex items-center gap-2.5 cursor-pointer shadow-md select-none border border-kindness/10"
              >
                <Plus className="w-5 h-5 shrink-0" strokeWidth={3} />
                <span className="text-sm md:text-base">+ Log a New Act of Kindness</span>
              </motion.button>
              
              <p className="text-[10px] md:text-xs text-muted-espresso mt-3">
                Tap anywhere above to open log screen. Best configured on shared kitchen tablets or wall dashboards.
              </p>
            </div>



            {/* Dynamic simulation controls to easily showcase milestone animations */}
            <div className="border border-amber-success/20 bg-amber-bg/25 rounded-2xl p-4 flex flex-col md:flex-row md:items-center justify-between gap-4 mt-6">
              <div className="space-y-0.5">
                <h5 className="text-xs font-extrabold text-amber-success uppercase tracking-wider flex items-center gap-1">
                  <Gift className="w-4 h-4 animate-bounce" />
                  <span>Developer Sandbox Point Booster</span>
                </h5>
                <p className="text-[11px] text-muted-espresso">
                  Add custom boost points to easily test crossing the 1,000 pt milestone and trigger the magnificent full-screen celebratory animation.
                </p>
              </div>
              <div className="flex gap-2 shrink-0">
                <button
                  onClick={() => handleSimulatePointsGift(15)}
                  className="bg-canvas hover:bg-surface border border-muted-espresso/15 text-xs font-bold px-3 py-1.5 rounded-lg text-primary-espresso cursor-pointer transition-all"
                >
                  +15 pts
                </button>
                <button
                  onClick={() => handleSimulatePointsGift(320)}
                  className="bg-canvas hover:bg-surface border border-muted-espresso/15 text-xs font-bold px-3 py-1.5 rounded-lg text-primary-espresso cursor-pointer transition-all text-amber-success"
                >
                  🎁 +320 Bonus
                </button>
                <button
                  onClick={() => handleSimulatePointsGift(1005)}
                  className="bg-amber-success hover:bg-amber-600 text-white text-xs font-bold px-3.5 py-1.5 rounded-lg cursor-pointer transition-all shadow-sm"
                >
                  🔥 Trigger Landmark Milestone (+1005 pts)
                </button>
              </div>
            </div>

          </div>
        )}

        {/* Router Viewport Layer: /admin (Parental Oversight ledger & timeline) */}
        {activeRoute === '/admin' && (
          <div className="space-y-6 animate-fade-in pb-16">
            
            {/* Admin Header with info */}
            <div className="bg-surface/50 border border-muted-espresso/10 p-5 rounded-3xl flex flex-col md:flex-row md:items-center justify-between gap-4">
              <div>
                <h3 className="font-bold text-base md:text-lg text-primary-espresso flex items-center gap-2">
                  <ShieldAlert className="w-5 h-5 text-kindness" />
                  <span>Parental Chronicle & Logs hub</span>
                </h3>
                <p className="text-xs text-muted-espresso mt-0.5">
                  Complete chronological oversight of household kindness values. Use inline edit capabilities to fix descriptions or reward values.
                </p>
              </div>

              <div className="flex items-center gap-2">
                <button
                  onClick={handleResetApplication}
                  className="text-xs font-semibold px-3 py-1.5 rounded-lg border border-red-500/10 text-red-500 bg-canvas hover:bg-red-50 transition-all cursor-pointer"
                >
                  Reload Mock Defaults
                </button>

                <button
                  onClick={() => {
                    setIsParentAuthenticated(false);
                    setActiveRoute('/dashboard');
                  }}
                  className="text-xs font-semibold px-3 py-1.5 rounded-lg border border-muted-espresso/10 bg-canvas text-primary-espresso hover:bg-surface transition-all cursor-pointer"
                >
                  Lock Panel & Return
                </button>
              </div>
            </div>

            {/* Total score panel admin display */}
            <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
              {[
                { label: 'Total Logs', value: entries.length, color: 'text-primary-espresso' },
                { label: 'Combined Points Earned', value: `${totalPoints} pts`, color: 'text-kindness' },
                { label: 'Times Met Fill Limit', value: completedMilestones, color: 'text-amber-success' },
                { label: 'Registered Relatives', value: members.length, color: 'text-primary-espresso' }
              ].map((item, i) => (
                <div key={i} className="bg-canvas border border-muted-espresso/10 p-4 rounded-2xl shadow-xs text-center">
                  <span className="block text-[10px] text-muted-espresso font-bold uppercase tracking-wider">{item.label}</span>
                  <span className={`text-xl font-bold mt-1 block ${item.color}`}>{item.value}</span>
                </div>
              ))}
            </div>

            {/* Interactive Family members tray representation */}
            <div className="bg-surface/15 border border-muted-espresso/5 rounded-3xl p-5 space-y-3.5">
              <div className="flex justify-between items-center px-1">
                <div className="space-y-0.5">
                  <h4 className="text-xs font-extrabold text-primary-espresso uppercase tracking-wider">
                    Our Household members
                  </h4>
                  <p className="text-[10px] text-muted-espresso">Family member contributions and stats for acts of kindness.</p>
                </div>
              </div>

              <div className="grid grid-cols-2 sm:grid-cols-6 gap-2">
                {members.map((m) => {
                  const submitCount = entries.filter((e) => e.submittedBy === m.id).length;
                  const beneficiaryCount = entries.filter((e) => e.beneficiary === m.id).length;
                  return (
                    <div 
                      key={m.id} 
                      className="bg-canvas border border-muted-espresso/10 p-3 rounded-2xl flex flex-col items-center text-center shadow-xs"
                    >
                      <span className="text-2xl mb-1 select-none">{m.avatar}</span>
                      <span className="text-xs font-bold text-primary-espresso truncate w-full">{m.name}</span>
                      <span className="text-[9px] text-muted-espresso mt-0.5 uppercase tracking-wide">
                        ★ {submitCount} Given • {beneficiaryCount} Recv
                      </span>
                    </div>
                  );
                })}
              </div>
            </div>

            {/* Search/Sort header helper for large logs */}
            <div className="flex justify-between items-center">
              <h4 className="font-bold text-sm text-primary-espresso">
                Acts of Kindness Ledger ({entries.length})
              </h4>
              <span className="text-xs text-muted-espresso font-medium select-none bg-surface/30 px-2.5 py-1 rounded-lg border border-muted-espresso/5">
                🔒 Live Sandbox Ledger synced to device Storage
              </span>
            </div>

            {/* Unbroken chronological layout feed */}
            <ActivityFeed 
              entries={entries}
              familyMembers={members}
              onDelete={handleDeleteEntry}
              onUpdate={handleUpdateEntry}
              isAdmin={true}
            />

          </div>
        )}

      </main>

      {/* Footer System Credit Info */}
      <footer className="max-w-4xl mx-auto border-t border-muted-espresso/10 text-center py-8 text-[11px] text-muted-espresso/70 mt-12 space-y-1 select-none">
        <p>© 2026 Household Central Network. All achievements saved offline on this device.</p>
        <p className="font-mono text-[10px]">Deployed Mode Node Ingress Injected • Port Localhost • Family Kindness Tracker MVP V1.0</p>
      </footer>

      {/* 6. LOG CONTEXT MODAL OVERLAY SHEET */}
      <LogModal
        isOpen={isLogModalOpen}
        onClose={() => setIsLogModalOpen(false)}
        onSubmit={handleAddNewEntry}
        familyMembers={members}
      />

      {/* 7. AUTHENTICATED LOCK ROUTER GATEWAY DISPLAY PROMPT */}
      <AnimatePresence>
        {showPinPrompt && (
          <div className="fixed inset-0 z-110 flex items-center justify-center p-4 bg-black/60 backdrop-blur-xs">
            <motion.div
              initial={{ scale: 0.9, opacity: 0 }}
              animate={{ scale: 1, opacity: 1 }}
              exit={{ scale: 0.9, opacity: 0 }}
              className="w-full max-w-sm bg-canvas border border-muted-espresso/15 p-6 rounded-3xl text-center shadow-xl space-y-5"
            >
              <div className="w-12 h-12 bg-amber-success/10 text-amber-success rounded-full flex items-center justify-center mx-auto">
                <Lock className="w-6 h-6" />
              </div>
              
              <div className="space-y-1">
                <h4 className="font-bold text-base text-primary-espresso">Parent Authorization Key Required</h4>
                <p className="text-xs text-muted-espresso">Enter parental PIN to verify administrative access.</p>
              </div>

              <form onSubmit={handleAuthSubmit} className="space-y-3.5">
                <input
                  type="password"
                  maxLength={4}
                  value={pinInput}
                  onChange={(e) => {
                    const cleanValue = e.target.value.replace(/\D/g, '');
                    setPinInput(cleanValue);
                    setPinError('');
                  }}
                  placeholder="PIN code (hint: 1234)"
                  className="w-full text-center tracking-widest text-lg font-bold p-2.5 rounded-xl border border-muted-espresso/15 focus:outline-none focus:ring-1 focus:ring-amber-success bg-surface/5"
                  autoFocus
                />

                {pinError && (
                  <p className="text-[11px] text-amber-success font-medium bg-amber-bg/45 p-1 px-2.5 rounded-lg border border-amber-success/15 select-none">
                    ⚠️ {pinError}
                  </p>
                )}

                <div className="flex gap-2 pt-1 text-xs">
                  <button
                    type="button"
                    onClick={() => {
                      setShowPinPrompt(false);
                      setPinInput('');
                      setPinError('');
                    }}
                    className="flex-1 py-2 rounded-xl border border-muted-espresso/10 hover:bg-surface text-primary-espresso font-semibold cursor-pointer transition"
                  >
                    Cancel
                  </button>
                  <button
                    type="submit"
                    className="flex-1 py-2 rounded-xl bg-amber-success hover:bg-amber-600 text-white font-bold cursor-pointer transition shadow-sm"
                  >
                    Verify Passcode
                  </button>
                </div>
              </form>
            </motion.div>
          </div>
        )}
      </AnimatePresence>

      {/* 8. CINEMATIC SUCCESS MILESTONE FULL OVERLAY SCREEN */}
      <CinematicMilestone
        isOpen={isCelebrationOpen}
        onClose={() => {
          setIsCelebrationOpen(false);
          setIsRadialGlowActive(false);
        }}
        milestoneNumber={celebrationMilestoneCount}
      />

    </div>
  );
}
</file>

