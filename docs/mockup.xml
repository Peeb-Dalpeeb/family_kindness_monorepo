                  rotate: [0, 5, -5, 0]
                }}
                transition={{ 
                  duration: 2.5, 
                  repeat: Infinity,
                  ease: 'easeInOut'
                }}
                className="p-5 rounded-full bg-amber-success/15 border border-amber-success/40 text-amber-success relative inline-block"
              >
                <Award className="w-16 h-16" />
