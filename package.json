{
  "name": "family-kindness-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "packages/shared",
    "packages/backend",
    "packages/frontend"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=packages/backend",
    "dev:frontend": "npm run dev --workspace=packages/frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "tsc --build",
    "build:backend": "tsc --build packages/backend",
    "build:frontend": "npm run build --workspace=packages/frontend",
    "build:shared": "tsc --build packages/shared",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "clean": "node -e \"const cp = require('child_process'); cp.execSync('tsc --build --clean', {stdio: 'inherit'}); cp.execSync('rimraf packages/backend/dist packages/frontend/dist packages/shared/dist', {stdio: 'inherit'});\"",
    "typecheck": "tsc --build"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.28.0",
    "eslint-plugin-tailwindcss": "^3.18.0",
    "prettier": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "rimraf": "^6.0.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.33.0"
  }
}
